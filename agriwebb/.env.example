# NOAA/NCEI weather station for official precipitation data
# Find stations at: https://www.ncei.noaa.gov/access/search/data-search/daily-summaries
NCEI_STATION_ID=

# AgriWebb API credentials
# Request API key from AgriWebb support (must be account admin)
AGRIWEBB_API_KEY=
AGRIWEBB_FARM_ID=

# Rain gauge sensor ID (created via setup command)
# Run: uv run python -m agriwebb.setup
AGRIWEBB_WEATHER_SENSOR_ID=

# Google Earth Engine Cloud project ID (for NDVI / satellite SDM)
# Auth uses ./agriwebb/service-account.json (not set here)
GEE_PROJECT_ID=

# Farm timezone (IANA format, e.g., "America/Los_Angeles")
# Optional — if unset, fetched from AgriWebb farm metadata
TZ=

# Pasture growth rate sync tolerance (kg DM/ha/day)
# Skip syncing if new value is within this tolerance of existing value
# Default: 1.0
GROWTH_RATE_TOLERANCE=1.0

# Display units for CLI output: "imperial" (°F/inches) or "metric" (°C/mm)
# AgriWebb API always uses metric internally regardless of this setting
# Default: imperial
DISPLAY_UNITS=imperial

# For GitHub Actions: add these as repository secrets
# Settings > Secrets and variables > Actions > New repository secret
